  {
    "id": "ssc_2016_q141",
    "question": "If x = 222, y = 223, z = 225 then the value of x + y + z - 3xyz is 3 3 3 x = 222, y = 223, z = 225 , x + y + z - 3xyz ?",
    "options": {
      "A": "4590",
      "B": "4690",
      "C": "4950",
      "D": "4960"
    },
    "correctAnswer": "B",
    "correctValue": "4690",
    "difficulty": "hard",
    "topic": "algebra",
    "year": 2016,
    "exam": "SSC CGL",
    "explanation": "Step 1: Given x+y = 222, xy = 223.\nStep 2: (x−y)² = (x+y)² − 4xy = 222² − 4×223 = 49284 − 892 = 48392. So x−y = 219.\nStep 3: x³−y³ = (x−y)[(x+y)²−xy] = 219×[49284−223] = 219×49061 = 10744359.\nFinal Answer: 4690"
  },
