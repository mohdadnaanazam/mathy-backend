  {
    "id": "ssc_2016_q157",
    "question": "A and B together can finish a work in 30 days. They worked for it for 20 days and then B left the work. The remaining work was done by A alone in 20 days more. In how many days can A alone finish the work? A B 30 䆾 䒦䒥 䒠䒟 20 , B A 䆾 20 A 䆾 ?",
    "options": {
      "A": "48 days 48",
      "B": "50 days 50",
      "C": "54 days 54",
      "D": "60 days 60"
    },
    "correctAnswer": "D",
    "correctValue": "60 days 60",
    "difficulty": "hard",
    "topic": "time_work",
    "year": 2016,
    "exam": "SSC CGL",
    "explanation": "Step 1: Together, A+B complete the work in 30 days. Work done in 20 days = 20/30 = 0.67.\nStep 2: Remaining work = 1 − 0.67 = 0.33. This is done by A alone in 20 days.\nStep 3: A's rate = 0.33/20. A alone = 1/rate = 60 days.\nFinal Answer: 60 days 60"
  },
