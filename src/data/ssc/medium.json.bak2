  {
    "id": "ssc_2018_q25",
    "question": "What will be the compound interest (nearest to ₹1) on a sum of ₹25,000 for 2 years at 12% p.a., if the interest is compounded 8-monthly ?",
    "options": {
      "A": "₹6,394",
      "B": "₹6,439",
      "C": "₹6,493",
      "D": "₹6,349"
    },
    "correctAnswer": "C",
    "correctValue": "₹6,493",
    "difficulty": "medium",
    "topic": "percentage",
    "year": 2018,
    "exam": "SSC CGL",
    "explanation": "Step 1: Formula: CI = P × [(1 + r/100)ⁿ − 1].\nStep 2: Substitute: 0 = P × [(1 + 12/100)^8 − 1].\nStep 3: Calculate factor = (1.12)^8 − 1, then P = CI / factor = ₹6,493.\nFinal Answer: ₹6,493"
  },
