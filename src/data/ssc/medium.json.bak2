    "id": "ssc_2018_q73",
    "question": "The radii of three concentric circles are in the ratio of 4 : 5 : 7. What is the ratio of the area between the two inner circles to that between the two outer circles?",
    "options": {
      "A": "3:8",
      "B": "4:7",
      "C": "5:9",
      "D": "4:5"
    },
    "correctAnswer": "A",
    "correctValue": "3:8",
    "difficulty": "medium",
    "topic": "ratio",
    "year": 2018,
    "exam": "SSC CGL",
    "explanation": "Step 1: Radii in ratio 4:5:7.\nStep 2: Area between inner circles = π(5²−4²) = 9π.\nStep 3: Area between outer circles = π(7²−5²) = 24π. Ratio = 3:8.\nFinal Answer: 3:8"
  },
