  {
    "id": "ssc_2018_q30",
    "question": "Three numbers are such that if the average of any two of them is added to the third number, the sums obtained are 168, 174 and 180 respectively. What is the average of the original three numbers ?",
    "options": {
      "A": "86",
      "B": "87",
      "C": "89",
      "D": "84"
    },
    "correctAnswer": "B",
    "correctValue": "87",
    "difficulty": "medium",
    "topic": "average",
    "year": 2018,
    "exam": "SSC CGL",
    "explanation": "Step 1: Each equation adds the average of two numbers to the third.\nStep 2: Summing all three equations: 2(x+y+z) = 168+174+180 = 522. So x+y+z = 261.\nStep 3: Average of original three numbers = 261 ÷ 3 = 87.0.\nFinal Answer: 87"
  },
  {
    "id": "ssc_2018_q34",
    "question": "Anu allows a discount on the marked price Of an article and still makes a profit Of 25%. If she gains ₹44.80 on the sale of the article, then the cost price of the article is:",
    "options": {
      "A": "₹188.80",
      "B": "₹192.80",
      "C": "₹184.20",
      "D": "₹179.20"
    },
    "correctAnswer": "D",
    "correctValue": "₹179.20",
    "difficulty": "medium",
    "topic": "percentage",
    "year": 2018,
    "exam": "SSC CGL",
    "explanation": "Step 1: Selling at 25.0% profit means gain = 25.0% of CP.\nStep 2: Given gain = ₹44.80. So CP = 44.80 ÷ (25.0/100) = 44.80 ÷ 0.25 = 179.20.\nFinal Answer: ₹179.20"
  },
